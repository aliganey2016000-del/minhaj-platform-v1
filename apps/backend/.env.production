# ───────────────────────────────────────────────────
#  Production Environment Variables
#  Masjid Al-Rahma Platform — Backend
#  NOTE: Set actual secret values in Coolify dashboard
# ───────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# MongoDB on VPS (Docker container, no auth for local connection)
MONGODB_URI=mongodb://127.0.0.1:27017/masjid-al-rahma

# JWT Secrets (SET THESE IN COOLIFY)
JWT_ACCESS_SECRET=SET_IN_COOLIFY
JWT_REFRESH_SECRET=SET_IN_COOLIFY

# Cookie Domain (empty = works with IP and any domain)
COOKIE_DOMAIN=

# Client URL (frontend origin — Contabo VPS)
CLIENT_URL=http://158.220.120.83

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL=info

# DeepSeek AI API Key (SET THIS IN COOLIFY)
DEEPSEEK_API_KEY=SET_IN_COOLIFY